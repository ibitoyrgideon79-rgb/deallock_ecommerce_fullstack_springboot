<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - DealLock</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

  <style>
    :root {
      --bg: #0a0f1a;
      --card: #0f172a;
      --text: #e2e8f0;
      --text-muted: #94a3b8;
      --primary: #3b82f6;
      --primary-dark: #2563eb;
      --danger: #ef4444;
      --border: rgba(148, 163, 184, 0.18);
      --navy: #0a1d37;
      --navy-hover: #112b52;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.5;
      min-height: 100vh;
    }

    header {
      background: #0b1324;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 1000;
      padding: 0.8rem 1.2rem;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 1600px;
      margin: 0 auto;
    }

    .logo-wrapper {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .logo img {
      height: 38px;
      width: auto;
      border-radius: 6px;
    }

    .slogan {
      color: var(--text-muted);
      font-size: 0.9rem;
      font-weight: 500;
    }

    .menu-toggle {
      font-size: 1.5rem;
      color: var(--text);
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
      display: none;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 1.6rem;
      list-style: none;
    }

    .nav-links a,
    .nav-links button:not(.nav-close) {
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
      padding: 0.5rem 0.8rem;
      border-radius: 8px;
      transition: all 0.15s ease;
    }

    .nav-links a:hover,
    .nav-links button:not(.nav-close):hover {
      background: rgba(59, 130, 246, 0.15);
      color: #60a5fa;
    }

 
    .notification-link {
      background: var(--navy) !important;
      border: none;
      border-radius: 50%;
      width: 38px;
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      cursor: pointer;
      transition: background 0.2s;
    }

    .notification-link:hover {
      background: var(--navy-hover) !important;
    }

    .notification-badge {
      position: absolute;
      top: -2px;
      right: -2px;
      background: #ef4444;
      color: white;
      font-size: 0.68rem;
      min-width: 18px;
      height: 18px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 4px;
      border: 1.8px solid var(--navy);
    }

   
    @media (max-width: 980px) {
      .menu-toggle {
        display: block;
      }

      .nav-links {
        position: fixed;
        inset: 0 0 0 30%;
        background: #0b1324e8;
        backdrop-filter: blur(10px);
        flex-direction: column;
        align-items: flex-start;
        padding: 5rem 1.5rem 2rem;
        transform: translateX(100%);
        transition: transform 0.28s ease;
        z-index: 999;
        display: flex;
      }

      .nav-links.active {
        transform: translateX(0);
      }

      .nav-close {
        position: absolute;
        top: 1.2rem;
        right: 1.2rem;
        background: transparent;
        border: none;
        color: var(--text);
        font-size: 2rem;
        cursor: pointer;
        padding: 0.5rem;
        line-height: 1;
        border-radius: 8px;
        transition: background 0.2s;
        /* prevent hover overflow */
        pointer-events: auto;
        touch-action: manipulation;
      }

      .nav-close:hover,
      .nav-close:focus {
        background: rgba(255,255,255,0.08);
      }

      .nav-links li {
        width: 100%;
      }

      .nav-links a,
      .nav-links button:not(.nav-close) {
        display: block;
        width: 100%;
        padding: 1rem 1.2rem;
        font-size: 1.1rem;
        border-radius: 10px;
      }
    }


    @media (min-width: 981px) {
      .nav-close {
        display: none !important;
      }
    }
    main.dashboard-container {
      max-width: 1600px;
      margin: 0 auto;
      padding: 1.5rem 1rem;
    }

    .admin-layout {
      display: grid;
      grid-template-columns: minmax(220px, 240px) 1fr;
      gap: 1.5rem;
    }

    .admin-sidebar {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.2rem;
      height: fit-content;
      position: sticky;
      top: 4.5rem;
    }

    .admin-main { min-width: 0; }

    .admin-section { display: none; }
    .admin-section.active { display: block; }

    .admin-section-title {
      background: #0f1b2b;
      color: white;
      padding: 0.6rem 1rem;
      border-radius: 10px;
      display: inline-block;
      margin-bottom: 1.2rem;
      font-size: 1.25rem;
      font-weight: 600;
    }

    .admin-folder-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-bottom: 1.4rem;
    }

    .admin-folder {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.45rem 1rem;
      border-radius: 999px;
      font-size: 0.82rem;
      background: rgba(148,163,184,0.08);
      border: 1px solid var(--border);
      color: var(--text);
      text-decoration: none;
      transition: all 0.15s;
    }

    .admin-folder:hover {
      background: rgba(59,130,246,0.15);
      border-color: rgba(96,165,250,0.4);
      color: #93c5fd;
    }

    .admin-deal-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.3rem;
      box-shadow: 0 8px 20px rgba(0,0,0,0.18);
    }

    .deal-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #f1f5f9;
      margin-bottom: 0.4rem;
    }

    .deal-status { color: var(--text-muted); font-size: 0.9rem; }

    .admin-deal-meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.8rem;
      margin: 1rem 0;
      font-size: 0.92rem;
    }

    .admin-deal-photo {
      width: 100%;
      max-width: 180px;
      height: 120px;
      object-fit: cover;
      border-radius: 10px;
      border: 1px solid var(--border);
    }

    .admin-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
      margin-top: 1.2rem;
    }

    .admin-action-btn {
      padding: 0.55rem 1.1rem;
      border-radius: 999px;
      font-size: 0.88rem;
      font-weight: 600;
      border: 1px solid rgba(148,163,184,0.3);
      background: rgba(148,163,184,0.07);
      color: var(--text);
      cursor: pointer;
      transition: all 0.15s;
    }

    .admin-action-btn:hover {
      background: rgba(59,130,246,0.18);
      border-color: rgba(96,165,250,0.55);
      color: #93c5fd;
    }

    .admin-action-btn.danger {
      border-color: rgba(239,68,68,0.5);
      color: #fecaca;
    }

    .admin-action-btn.danger:hover {
      background: rgba(239,68,68,0.18);
      color: #fee2e2;
    }

    .btn-submit, .btn-cancel {
      padding: 0.6rem 1.4rem;
      border-radius: 8px;
      font-weight: 600;
      cursor: pointer;
    }

    .btn-submit {
      background: var(--primary);
      color: white;
      border: none;
    }

    .btn-cancel {
      background: rgba(148,163,184,0.15);
      color: var(--text);
      border: 1px solid var(--border);
      text-decoration: none;
    }

    .signup-error {
      background: rgba(239,68,68,0.15);
      color: #fecaca;
      padding: 0.8rem 1.2rem;
      border-radius: 8px;
      border-left: 4px solid var(--danger);
      margin-bottom: 1rem;
    }

    .admin-nav-btn, .admin-nav-link {
      width: 100%;
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.85rem 1rem;
      border-radius: 10px;
      background: transparent;
      color: var(--text);
      border: none;
      font-weight: 600;
      text-align: left;
      cursor: pointer;
      transition: all 0.15s;
    }

    .admin-nav-btn:hover, .admin-nav-link:hover {
      background: rgba(148,163,184,0.1);
    }

    .admin-nav-btn.active {
      background: rgba(59,130,246,0.22);
      color: #93c5fd;
    }

    .admin-nav-title {
      color: #cbd5e1;
      font-size: 0.9rem;
      font-weight: 600;
      margin-bottom: 0.8rem;
      padding-left: 0.2rem;
    }

    @media (max-width: 980px) {
      .admin-layout { grid-template-columns: 1fr; }
      .admin-sidebar { position: static; margin-bottom: 1.5rem; }
    }

    @media (max-width: 600px) {
      .admin-deal-meta { grid-template-columns: 1fr; }
      .admin-actions { flex-direction: column; }
      .admin-action-btn { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>

<header>
  <nav class="navbar">
    <div class="logo-wrapper">
      <a href="/" class="logo">
        <img src="/frontend/logo.jpeg" alt="DealLock Logo">
      </a>
      <span class="slogan">Admin Dashboard</span>
    </div>

    <button class="menu-toggle" id="menu-toggle" aria-label="Toggle menu">
      <i class="fas fa-bars"></i>
    </button>

    <ul class="nav-links" id="nav-links">
      <button class="nav-close" id="nav-close" aria-label="Close menu">
        <i class="fas fa-xmark"></i>
      </button>

      <li class="notification-item">
        <button type="button" class="notification-link" id="notifToggle">
          <i class="fa-regular fa-bell"></i>
          <span class="notification-badge" th:if="${notificationCount != null && notificationCount > 0}" th:text="${notificationCount}">0</span>
        </button>
      </li>

      <li><a href="/">Home</a></li>
      <li><a href="/dashboard">User Dashboard</a></li>
      <li><a href="/profile">Profile</a></li>
      <li><a href="/admin">Admin Console</a></li>
      <li><a href="/logout">Log out</a></li>
    </ul>
  </nav>
</header>

<main class="dashboard-container">
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-nav-title">Navigation</div>
      <button class="admin-nav-btn active" data-target="section-pending"><i class="fa-regular fa-clock"></i> Pending Deals</button>
      <button class="admin-nav-btn" data-target="section-approved"><i class="fa-regular fa-circle-check"></i> Approved Deals</button>
      <button class="admin-nav-btn" data-target="section-confirmed"><i class="fa-solid fa-check-double"></i> Confirmed Payments</button>
      <button class="admin-nav-btn" data-target="section-not-received"><i class="fa-regular fa-circle-xmark"></i> Payment Not Received</button>
      <button class="admin-nav-btn" data-target="section-secured"><i class="fa-solid fa-lock"></i> Secured Deals</button>
      <button class="admin-nav-btn" data-target="section-rejected"><i class="fa-regular fa-circle-xmark"></i> Rejected Deals</button>
      <a class="admin-nav-link" href="/admin/payment-proofs"><i class="fa-regular fa-folder-open"></i> Payment Proofs</a>
    </aside>

    <section class="admin-main">

        <div class="admin-folder-row">
          <a href="/admin/payment-proofs" class="admin-folder"><i class="fa-regular fa-folder-open"></i> Payment Proofs</a>
          <a href="#confirmed-payments" class="admin-folder"><i class="fa-regular fa-circle-check"></i> Confirmed Payments</a>
          <a href="#payment-not-received" class="admin-folder"><i class="fa-regular fa-circle-xmark"></i> Payment Not Received</a>
          <a href="#secured-deals" class="admin-folder"><i class="fa-solid fa-lock"></i> Secured Deals</a>
        </div>

        <form method="get" action="/admin" style="display:flex; flex-wrap:wrap; gap:1rem; margin-bottom:1.6rem; align-items:flex-end;">
          <div style="display:flex; flex-direction:column; gap:0.4rem;">
            <label for="start-date">Start Date</label>
            <input type="date" id="start-date" name="start" th:value="${start}">
          </div>
          <div style="display:flex; flex-direction:column; gap:0.4rem;">
            <label for="end-date">End Date</label>
            <input type="date" id="end-date" name="end" th:value="${end}">
          </div>
          <button type="submit" class="btn-submit">Filter</button>
          <a href="/admin" class="btn-cancel">Clear</a>
        </form>

        <div class="admin-section active" id="section-pending">
          <h2 class="admin-section-title">Pending Deals</h2>

          <div th:if="${message}" class="signup-error">
            <span th:if="${message == 'approved'}">Deal approved.</span>
            <span th:if="${message == 'rejected'}">Deal rejected.</span>
          </div>

          <div th:if="${#lists.isEmpty(pendingDeals)}">
            <p style="color:var(--text-muted);">No pending deals at the moment.</p>
          </div>

          <div th:if="${!#lists.isEmpty(pendingDeals)}" style="display:flex; flex-direction:column; gap:1.2rem;">
            <div th:each="deal : ${pendingDeals}" class="admin-deal-card">
              <div class="deal-title" th:text="${deal.title}">Deal Title</div>
              <div class="deal-status">Pending Approval</div>

              <div class="admin-deal-meta">
                <div th:text="'₦' + ${deal.value}">₦0</div>
                <div th:text="${deal.clientName}">Client</div>
                <div th:text="${deal.link}">Link</div>
              </div>

              <div th:if="${deal.itemPhoto != null}">
                <img th:src="@{'/api/deals/' + ${deal.id} + '/photo'}" alt="Item photo" class="admin-deal-photo">
              </div>

              <div class="admin-actions">
                <a th:href="@{'/dashboard/deal/' + ${deal.id}}" class="admin-action-btn">View Details</a>
                <form th:action="@{'/admin/deals/' + ${deal.id} + '/approve'}" method="post" class="admin-action-form" data-action="approve">
                  <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>
                  <button type="submit" class="admin-action-btn">Approve</button>
                </form>
                <form th:action="@{'/admin/deals/' + ${deal.id} + '/reject'}" method="post" data-action="reject">
                  <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>
                  <button type="submit" class="admin-action-btn danger">Reject</button>
                </form>
                <form th:action="@{'/admin/deals/' + ${deal.id} + '/delete'}" method="post" data-action="delete" onsubmit="return confirm('Really delete this deal?');">
                  <input type="hidden" th:name="${_csrf.parameterName}" th:value="${_csrf.token}"/>
                  <button type="submit" class="admin-action-btn danger">Delete</button>
                </form>
              </div>
            </div>
          </div>
        </div>

       

      </section>
  </div>
</main>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const navLinks   = document.getElementById('nav-links');
  const navClose   = document.getElementById('nav-close');
  const menuIcon   = menuToggle?.querySelector('i');

  function closeMenu() {
    if (navLinks) navLinks.classList.remove('active');
    if (menuIcon) menuIcon.className = 'fas fa-bars';
  }

  if (menuToggle && navLinks) {
    menuToggle.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('active');
      if (menuIcon) {
        menuIcon.className = isOpen ? 'fas fa-xmark' : 'fas fa-bars';
      }
    });
  }

  if (navClose) {
    navClose.addEventListener('click', closeMenu);
  }

  document.addEventListener('click', (e) => {
    if (navLinks && menuToggle &&
        !navLinks.contains(e.target) &&
        !menuToggle.contains(e.target)) {
      closeMenu();
    }
  });

  document.querySelectorAll('.admin-nav-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.admin-nav-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.admin-section').forEach(sec => sec.classList.remove('active'));
      const target = document.getElementById(btn.dataset.target);
      if (target) target.classList.add('active');
    });
  });

  document.querySelectorAll('.admin-action-form').forEach(form => {
    form.addEventListener('submit', () => {
      const btn = form.querySelector('button');
      if (btn) {
        btn.disabled = true;
        btn.classList.add('is-processing');
        const action = form.dataset.action || '';
        if (action === 'approve')        btn.textContent = 'Approving...';
        else if (action === 'reject')    btn.textContent = 'Rejecting...';
        else if (action === 'delete')    btn.textContent = 'Deleting...';
        else if (action === 'payment-confirmed') btn.textContent = 'Confirming...';
        else if (action === 'payment-not-received') btn.textContent = 'Updating...';
        else if (action === 'secured')   btn.textContent = 'Securing...';
      }
    });
  });
</script>
</body>
</html>
